# 实验 2：ReLU + 大初始化（梯度爆炸）
print("\n--- 实验 2: ReLU + 大初始化 (梯度爆炸/NaN) ---")

class DeepNetReLUBig(nn.Module):
    def __init__(self, num_layers=20, hidden_size=256):
        super().__init__()
        layers = []
        for _ in range(num_layers):
            layers.append(nn.Linear(hidden_size, hidden_size))
            layers.append(nn.ReLU())
        self.network = nn.Sequential(*layers)
    
    def forward(self, x):
        return self.network(x)

model2 = DeepNetReLUBig(num_layers=20, hidden_size=256)

# 使用较大的初始化
for m in model2.modules():
    if isinstance(m, nn.Linear):
        nn.init.normal_(m.weight, mean=0, std=10)

model2.to(device)

try:
    # 前向传播
    output2 = model2(x)
    
    # 反向传播
    output2.sum().backward()
    
    # 检查是否有 NaN
    has_nan = any(
        m.weight.grad.isnan().any() 
        for m in model2.modules() 
        if isinstance(m, nn.Linear) and m.weight.grad is not None
    )
    
    if has_nan:
        print("检测到 NaN 值 - 梯度爆炸或数值溢出!")
    else:
        gradient_norms_2 = []
        for m in model2.modules():
            if isinstance(m, nn.Linear):
                if m.weight.grad is not None:
                    grad_norm = m.weight.grad.norm().item()
                    gradient_norms_2.append(grad_norm)
        
        print(f"前5层梯度范数: {gradient_norms_2[:5]}")
        print(f"后5层梯度范数: {gradient_norms_2[-5:]}")
        
except RuntimeError as e:
    print(f"发生错误: {e}")
    print("这通常是数值溢出导致的结果")
