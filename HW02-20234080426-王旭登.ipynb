```python
# 定义激活函数和损失函数
print("\n[4] 定义激活函数和损失函数...")

def relu(x):
    """ReLU 激活函数"""
    return torch.clamp(x, min=0)

def relu_derivative(x):
    """ReLU 导数"""
    return (x > 0).float()

def softmax(x):
    """Softmax 函数"""
    exp_x = torch.exp(x - torch.max(x, dim=1, keepdim=True)[0])
    return exp_x / torch.sum(exp_x, dim=1, keepdim=True)

def cross_entropy_loss(y_pred, y_true):
    """交叉熵损失"""
    m = y_true.shape[0]
    p = torch.clamp(y_pred, min=1e-10)
    return -torch.sum(y_true * torch.log(p)) / m

print("ReLU, Softmax, 交叉熵损失函数已定义")
```

```python
# 前向传播
print("\n[5] 前向传播实现...")

def forward(X, W1, b1, W2, b2):
    """前向传播"""
    # 隐藏层
    z1 = torch.mm(X, W1) + b1
    a1 = relu(z1)
    # 输出层
    z2 = torch.mm(a1, W2) + b2
    a2 = softmax(z2)
    return a1, a2, z1

# 转换为 PyTorch 张量
X_train_tensor = torch.tensor(X_train, dtype=torch.float32, device=device)
X_test_tensor = torch.tensor(X_test, dtype=torch.float32, device=device)
y_train_tensor = torch.tensor(y_train_onehot, dtype=torch.float32, device=device)
y_test_tensor = torch.tensor(y_test_onehot, dtype=torch.float32, device=device)

# 测试前向传播
test_output, _, _ = forward(X_train_tensor[:10], W1, b1, W2, b2)
print(f"测试输出形状: {test_output.shape}")
print("前向传播测试通过")
