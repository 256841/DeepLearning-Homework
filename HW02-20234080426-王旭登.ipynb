## 5 泛化表现，协变量偏移和对抗性数据

### 5.1 理论计算题

```python
print("\n" + "=" * 60)
print("5.1 理论计算题 - 协变量偏移与标签偏移")
print("=" * 60)

print("""
1. 协变量偏移 (Covariate Shift)：
   - 特征分布发生变化: P(x) ≠ Q(x)
   - 条件分布不变: P(y|x) = Q(y|x)
   
   生活例子：医疗诊断
   - 训练数据：年轻人群体的X光片
   - 测试数据：老年人群体的X光片
   - 特征分布变化（年龄差异），但诊断规则不变

2. 标签偏移 (Label Shift)：
   - 标签分布发生变化: P(y) ≠ Q(y)
   - 条件分布不变: P(x|y) = Q(x|y)
   
   生活例子：电商推荐
   - 训练数据：疫情前的购物偏好
   - 测试数据：疫情后的购物偏好
   - 商品特征分布相似，但购买偏好（标签）发生变化

联系：两者都描述了训练和测试分布不一致的问题，
      都可能导致模型泛化性能下降。
""")
```

### 5.2 编程题 - 协变量偏移校正

```python
print("\n" + "=" * 60)
print("5.2 编程题 - 协变量偏移模拟与校正")
print("=" * 60)

np.random.seed(42)

# 1. 构造训练集 P
print("\n[1] 构造训练集 P...")
n_train = 1000
X_train_p = np.random.normal(-1, 1, n_train).reshape(-1, 1)
epsilon = np.random.normal(0, 0.5, n_train).reshape(-1, 1)
y_train_p = 2 * X_train_p + epsilon

print(f"训练集 P 形状: X={X_train_p.shape}, y={y_train_p.shape}")
print(f"训练集 X 分布: 均值={X_train_p.mean():.3f}, 标准差={X_train_p.std():.3f}")

# 2. 构造测试集 Q（协变量偏移）
print("\n[2] 构造测试集 Q（协变量偏移）...")
n_test = 500
X_test_q = np.random.normal(2, 1, n_test).reshape(-1, 1)
epsilon_test = np.random.normal(0, 0.5, n_test).reshape(-1, 1)
y_test_q = 2 * X_test_q + epsilon_test

print(f"测试集 Q 形状: X={X_test_q.shape}, y={y_test_q.shape}")
print(f"测试集 X 分布: 均值={X_test_q.mean():.3f}, 标准差={X_test_q.std():.3f}")
```

```python
# 3. 基线模型：直接在线性回归
print("\n[3] 基线模型：直接训练线性回归...")

class LinearRegression:
    def __init__(self):
        self.weights = None
        self.bias = None
    
    def fit(self, X, y, learning_rate=0.01, epochs=1000):
        n_samples, n_features = X.shape
        self.weights = np.zeros(n_features)
        self.bias = 0
        
        for _ in range(epochs):
            y_pred = np.dot(X, self.weights) + self.bias
            dw = (1/n_samples) * np.dot(X.T, (y_pred - y))
            db = (1/n_samples) * np.sum(y_pred - y)
            self.weights -= learning_rate * dw
            self.bias -= learning_rate * db
    
    def predict(self, X):
        return np.dot(X, self.weights) + self.bias

# 训练基线模型
baseline_model = LinearRegression()
baseline_model.fit(X_train_p, y_train_p, learning_rate=0.01, epochs=1000)

# 在测试集上评估
y_pred_baseline = baseline_model.predict(X_test_q)
mse_baseline = np.mean((y_test_q - y_pred_baseline) ** 2)

print(f"基线模型参数: w={baseline_model.weights[0]:.4f}, b={baseline_model.bias:.4f}")
print(f"基线模型在测试集 Q 上的 MSE: {mse_baseline:.4f}")
```

```python
# 4. 协变量偏移校正
print("\n[4] 协变量偏移校正...")

from sklearn.linear_model import LogisticRegression

# 合并数据用于训练分类器
X_combined = np.vstack([X_train_p, X_test_q])
y_combined = np.hstack([np.zeros(n_train), np.ones(n_test)]).reshape(-1, 1)

# 训练逻辑回归分类器（估计 P(test|x)）
print("训练分类器估计样本权重...")
classifier = LogisticRegression()
classifier.fit(X_combined, y_combined.ravel())

# 预测每个训练样本属于测试集的概率
prob_test_given_x = classifier.predict_proba(X_train_p)[:, 1]

# 计算权重: w_i ∝ P(test|x) / P(train|x)
# 由于 P(train|x) = 1 - P(test|x)，所以 w_i ∝ P(test|x) / (1 - P(test|x))
# 为了数值稳定，使用公式: w_i = P(test|x) / (1 - P(test|x))
sample_weights = prob_test_given_x / (1 - prob_test_given_x + 1e-10)

# 归一化权重
sample_weights = sample_weights / sample_weights.mean()

print(f"权重范围: [{sample_weights.min():.4f}, {sample_weights.max():.4f}]")
print(f"权重均值: {sample_weights.mean():.4f}")
```

```python
# 5. 加权模型训练
print("\n[5] 加权模型训练...")

class WeightedLinearRegression:
    def __init__(self):
        self.weights = None
        self.bias = None
    
    def fit(self, X, y, weights, learning_rate=0.01, epochs=1000):
        n_samples, n_features = X.shape
        self.weights = np.zeros(n_features)
        self.bias = 0
        
        for _ in range(epochs):
            y_pred = np.dot(X, self.weights) + self.bias
            error = y_pred - y
            
            # 加权梯度
            dw = (1/n_samples) * np.dot(X.T, (error * weights))
            db = (1/n_samples) * np.sum(error * weights)
            
            self.weights -= learning_rate * dw
            self.bias -= learning_rate * db
    
    def predict(self, X):
        return np.dot(X, self.weights) + self.bias

# 训练加权模型
weighted_model = WeightedLinearRegression()
weighted_model.fit(X_train_p, y_train_p, sample_weights, learning_rate=0.01, epochs=1000)

# 在测试集上评估
y_pred_weighted = weighted_model.predict(X_test_q)
mse_weighted = np.mean((y_test_q - y_pred_weighted) ** 2)

print(f"加权模型参数: w={weighted_model.weights[0]:.4f}, b={weighted_model.bias:.4f}")
print(f"加权模型在测试集 Q 上的 MSE: {mse_weighted:.4f}")
```

