model3 = DeepNetXavier(num_layers=20, hidden_size=256)

# Xavier 初始化
for m in model3.modules():
    if isinstance(m, nn.Linear):
        nn.init.xavier_uniform_(m.weight)
        nn.init.zeros_(m.bias)

model3.to(device)

# 前向传播
output3 = model3(x)

# 反向传播
output3.sum().backward()

# 记录梯度范数
gradient_norms_3 = []
for m in model3.modules():
    if isinstance(m, nn.Linear):
        if m.weight.grad is not None:
            grad_norm = m.weight.grad.norm().item()
            gradient_norms_3.append(grad_norm)

print(f"前5层梯度范数: {gradient_norms_3[:5]}")
print(f"后5层梯度范数: {gradient_norms_3[-5:]}")
print(f"最小梯度范数: {min(gradient_norms_3):.2e}")
print(f"最大梯度范数: {max(gradient_norms_3):.2e}")

# 验证是否在合理区间
in_range = all(1e-6 < norm < 1e3 for norm in gradient_norms_3)
print(f"梯度是否稳定在合理区间 [1e-6, 1e3]: {'是' if in_range else '否'}")
