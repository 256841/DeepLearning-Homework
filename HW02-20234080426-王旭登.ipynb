W1_new.requires_grad_(True)
b1_new.requires_grad_(True)
W2_new.requires_grad_(True)
b2_new.requires_grad_(True)

def dropout_layer(X, dropout_rate, is_training=True):
    """
    Dropout 实现
    
    参数：
    - X: 输入张量
    - dropout_rate: dropout 概率
    - is_training: 是否在训练模式（测试时不触发Dropout）
    
    返回：
    - 经过 dropout 处理后的张量
    """
    if not is_training or dropout_rate == 0:
        return X
    
    # 生成随机掩码
    mask = (torch.rand_like(X) > dropout_rate).float()
    
    # 应用掩码并缩放
    output = X * mask
    
    # 缩放以保持期望值不变
    output = output / (1 - dropout_rate)
    
    return output

print("Dropout 层实现完成")
```

```python
# 带 Dropout 的前向传播
def forward_with_dropout(X, W1, b1, W2, b2, dropout_rate, is_training=True):
    """带 Dropout 的前向传播"""
    # 隐藏层
    z1 = torch.mm(X, W1) + b1
    a1 = relu(z1)
    
    # 应用 Dropout
    a1 = dropout_layer(a1, dropout_rate, is_training)
    
    # 输出层
    z2 = torch.mm(a1, W2) + b2
    a2 = softmax(z2)
    
    return a1, a2, z1

# 带 L2 正则化和 Dropout 的训练函数
def train_epoch_with_reg(W1, b1, W2, b2, X, y, learning_rate, dropout_rate, lambda_reg):
    """带 L2 正则化和 Dropout 的训练"""
    # 前向传播（训练时使用 Dropout）
    a1, y_pred, z1 = forward_with_dropout(X, W1, b1, W2, b2, dropout_rate, True)
    
    # 计算损失
    loss = cross_entropy_loss(y_pred, y)
    
    # 添加 L2 正则化
    if lambda_reg > 0:
        reg_loss = lambda_reg * (torch.sum(W1**2) + torch.sum(W2**2))
        loss = loss + reg_loss
    
    # 清零梯度
    if W1.grad is not None:
        W1.grad.zero_()
    if b1.grad is not None:
        b1.grad.zero_()
    if W2.grad is not None:
        W2.grad.zero_()
    if b2.grad is not None:
        b2.grad.zero_()
    
    # 反向传播
    loss.backward()
    
    # SGD 参数更新（带权重衰减）
    with torch.no_grad():
        W1 -= learning_rate * W1.grad
        b1 -= learning_rate * b1.grad
        W2 -= learning_rate * W2.grad
        b2 -= learning_rate * b2.grad
    
    return loss.item()

print("L2 正则化和 Dropout 实现完成")
```

