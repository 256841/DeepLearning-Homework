# 检查 PyTorch 版本
print(f"PyTorch 版本: {torch.__version__}")
print(f"使用设备: {device}")

# 实验 1：Sigmoid + 普通初始化（梯度消失）
print("\n--- 实验 1: Sigmoid + 高斯初始化 (梯度消失) ---")

class DeepNetSigmoid(nn.Module):
    def __init__(self, num_layers=20, hidden_size=256):
        super().__init__()
        layers = []
        for _ in range(num_layers):
            layers.append(nn.Linear(hidden_size, hidden_size))
            layers.append(nn.Sigmoid())
        self.network = nn.Sequential(*layers)
    
    def forward(self, x):
        return self.network(x)

model1 = DeepNetSigmoid(num_layers=20, hidden_size=256)

# 初始化为较大的权重
for m in model1.modules():
    if isinstance(m, nn.Linear):
        nn.init.normal_(m.weight, mean=0, std=1)

model1.to(device)

# 创建输入数据
x = torch.randn(32, 256, device=device)

# 前向传播
output1 = model1(x)

# 反向传播
output1.sum().backward()

# 记录梯度范数
gradient_norms_1 = []
for i, m in enumerate(model1.modules()):
    if isinstance(m, nn.Linear):
        if m.weight.grad is not None:
            grad_norm = m.weight.grad.norm().item()
            gradient_norms_1.append(grad_norm)

print(f"前5层梯度范数: {gradient_norms_1[:5]}")
print(f"后5层梯度范数: {gradient_norms_1[-5:]}")
print(f"最小梯度范数: {min(gradient_norms_1):.2e}")
print(f"最大梯度范数: {max(gradient_norms_1):.2e}")
```

