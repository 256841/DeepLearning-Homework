```python
# 训练函数
print("\n[6] 训练函数实现...")

def train_epoch(W1, b1, W2, b2, X, y, learning_rate):
    """训练一个 epoch"""
    # 前向传播
    a1, y_pred, z1 = forward(X, W1, b1, W2, b2)
    
    # 计算损失
    loss = cross_entropy_loss(y_pred, y)
    
    # 清零梯度（重要！）
    if W1.grad is not None:
        W1.grad.zero_()
    if b1.grad is not None:
        b1.grad.zero_()
    if W2.grad is not None:
        W2.grad.zero_()
    if b2.grad is not None:
        b2.grad.zero_()
    
    # 反向传播
    loss.backward()
    
    # SGD 参数更新（手动）
    with torch.no_grad():
        W1 -= learning_rate * W1.grad
        b1 -= learning_rate * b1.grad
        W2 -= learning_rate * W2.grad
        b2 -= learning_rate * b2.grad
    
    return loss.item()

def evaluate(W1, b1, W2, b2, X, y):
    """评估模型"""
    _, y_pred, _ = forward(X, W1, b1, W2, b2)
    loss = cross_entropy_loss(y_pred, y)
    predictions = torch.argmax(y_pred, dim=1)
    labels = torch.argmax(y, dim=1)
    accuracy = torch.mean((predictions == labels).float())
    return loss.item(), accuracy.item()

print("训练函数实现完成")
```

